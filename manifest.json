{
  "manifest_version": 3,
  "name": "ScrollCut — Reels & Shorts Limiter",
  "version": "1.0.0",
  "description": "Limit daily time on Instagram Reels & YouTube Shorts. Set your limit, get blocked when you hit it. Free. No account needed.",
  "permissions": [
    "alarms",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "onboarding.html",
        "onboarding.js",
        "popup-init.js",
        "goodbye.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}